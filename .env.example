# OUTLOCAL Environment Variables
# Copy to .env and fill in your values

# === AI Engine (Free Cloud LLMs — no credit card needed) ===
# Groq (Primary) — https://console.groq.com → Create API Key
GROQ_API_KEY=gsk_...

# OpenRouter (Fallback) — https://openrouter.ai → Create API Key
OPENROUTER_API_KEY=sk-or-...

# Google AI Studio (Fallback) — https://aistudio.google.com → Get API Key
GEMINI_API_KEY=AIza...

# === Email Sending ===
# SMTP credentials for sending cold emails
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=your-email@example.com
SMTP_FROM_NAME=Your Name

# === Google Maps Scraping ===
# Optional: Google Places API key for enhanced scraping
# GOOGLE_PLACES_API_KEY=AIza...

# === Application ===
APP_ENV=development
APP_PORT=8000
APP_HOST=0.0.0.0
DATABASE_URL=sqlite:///./outlocal.db

# === Compliance ===
# Physical address required by CAN-SPAM
BUSINESS_ADDRESS=Your Business Address, City, Postcode, UK
UNSUBSCRIBE_URL=https://yourdomain.com/unsubscribe
